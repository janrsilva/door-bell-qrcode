#!/bin/sh
set -eu

if [ "${SKIP_APP_VERSION_PUSH_CHECK:-}" = "1" ]; then
  exit 0
fi

before_status="$(git status --short)"
if [ -n "$before_status" ]; then
  cat <<'MSG'

Existem mudanças locais não commitadas.
Faça commit ou limpe a worktree antes do push para garantir que a versão exibida foi enviada.

MSG
  exit 1
fi

node scripts/write-app-version.js
after_status="$(git status --short)"

if [ "$before_status" != "$after_status" ]; then
  cat <<'MSG'

O hook atualizou a versão do PWA para o minuto atual.
Faça um commit dessa alteração e execute o push novamente.

Isso garante que a versão exibida no resident/visitor seja a mesma versão enviada.

MSG
  exit 1
fi
