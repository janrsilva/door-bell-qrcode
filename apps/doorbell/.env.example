# Database
DATABASE_URL="postgresql://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require&schema=public&pgbouncer=true"

# Public app URL.
# Local: http://localhost:3333
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3333"
NEXTAUTH_URL="http://localhost:3333"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Optional: comma-separated dev origins for ngrok/Tailscale while running next dev.
# Example: NEXT_ALLOWED_DEV_ORIGINS="my-host.tailnet.ts.net,abc.ngrok-free.app"
NEXT_ALLOWED_DEV_ORIGINS=""

# Web Push / VAPID
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Firebase client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_DATABASE_URL=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Firebase Admin SDK service account JSON encoded as base64.
# Example:
# base64 -i service-account.json | tr -d '\n'
FIREBASE_ADMIN_SA_JSON=""
